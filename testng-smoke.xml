<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- Run only tests having group smoke from tests package. -->
<suite name="API Automation Smoke Suite">
    <listeners>
        <listener class-name="listeners.RetryAnnotationTransformer"/>
    </listeners>

    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>

        <packages>
            <package name="tests"/>
        </packages>
    </test>
</suite>
