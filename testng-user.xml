<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- Run only tests having group user from tests package. -->
<suite name="API Automation Regression Suite"
       verbose="2"
       parallel="classes"
       thread-count="3">

    <!-- Environment -->
    <parameter name="environment" value="QA"/>

    <!-- Listeners -->
    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <test name="User API Tests">
        <groups>
            <run>
                <include name="user"/>
            </run>
        </groups>

        <classes>
            <class name="tests.UserTestsUsingDataProvider"/>
            <class name="tests.UserTestsUsingMap"/>
            <class name="tests.UserTestsUsingFaker"/>
            <class name="tests.UserNegativeTests"/>
        </classes>
    </test>

</suite>