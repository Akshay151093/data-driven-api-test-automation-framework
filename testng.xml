<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="API Automation Regression Suite"
       verbose="2"
       parallel="classes"
       thread-count="3">

    <!-- Environment -->
    <parameter name="environment" value="QA"/>

    <!-- Listeners -->
    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <!-- Tests -->
    <test name="User API Tests">
        <classes>
            <class name="test.UserTestsUsingDataProvider"/>
            <class name="test.UserTestsUsingMap"/>
            <class name="test.UserTestsUsingFaker"/>
        </classes>
    </test>

</suite>