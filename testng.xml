<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- Run all the tests -->
<suite name="API Automation Master Suite"
       verbose="2"
       parallel="classes"
       thread-count="3">

    <listeners>
        <listener class-name="listeners.RetryAnnotationTransformer"/>
    </listeners>

    <test name="User API Tests">
        <classes>
            <class name="tests.UserTestsUsingDataProvider"/>
            <class name="tests.UserTestsUsingMap"/>
            <class name="tests.UserTestsUsingFaker"/>
            <class name="tests.UserNegativeTests"/>
        </classes>
    </test>

</suite>
